# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL – required; no SQLite for the running app)
# Docker: postgres/postgres/tourist_assistant. Local: set POSTGRES_USER/POSTGRES_DB to match your DB.
DATABASE_URL=postgres://postgres:postgres@db:5432/tourist_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tourist_assistant

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=media

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
